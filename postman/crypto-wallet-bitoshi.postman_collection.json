{
  "info": {
    "name": "Crypto Wallet Bitoshi API",
    "_postman_id": "e6b31b8c-b7fc-45c7-935c-6433a3a41f67",
    "description": "Collection for all API endpoints, including non-production mock failure testing.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000"
    },
    {
      "key": "apiPrefix",
      "value": "api/v1"
    },
    {
      "key": "apiKey",
      "value": "bitoshi-local-key"
    },
    {
      "key": "walletId",
      "value": "wallet_1"
    },
    {
      "key": "cursor",
      "value": ""
    },
    {
      "key": "idempotencyKey",
      "value": "idem-123"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Get Health",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "health"
              ]
            },
            "description": "Basic liveness endpoint."
          }
        },
        {
          "name": "Get DB Health",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/health/db",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "health",
                "db"
              ]
            },
            "description": "Database connectivity health check."
          }
        }
      ]
    },
    {
      "name": "Observability",
      "item": [
        {
          "name": "Get Metrics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/metrics",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "metrics"
              ]
            },
            "description": "Prometheus metrics snapshot."
          }
        }
      ]
    },
    {
      "name": "Wallet",
      "item": [
        {
          "name": "Get Wallet",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/wallets/{{walletId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "wallets",
                "{{walletId}}"
              ]
            },
            "description": "Fetch a wallet by id."
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "List Wallet Transactions",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/wallets/{{walletId}}/transactions?cursor={{cursor}}&limit=20&asset=BTC&status=pending",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "wallets",
                "{{walletId}}",
                "transactions"
              ],
              "query": [
                {
                  "key": "cursor",
                  "value": "{{cursor}}"
                },
                {
                  "key": "limit",
                  "value": "20"
                },
                {
                  "key": "asset",
                  "value": "BTC"
                },
                {
                  "key": "status",
                  "value": "pending"
                }
              ]
            },
            "description": "List wallet transactions with optional cursor pagination and filters."
          }
        },
        {
          "name": "Create Withdrawal",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              },
              {
                "key": "idempotency-key",
                "value": "{{idempotencyKey}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"asset\": \"BTC\",\n  \"amount\": \"0.01\",\n  \"toAddress\": \"bc1qexample\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/wallets/{{walletId}}/withdrawals",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "wallets",
                "{{walletId}}",
                "withdrawals"
              ]
            },
            "description": "Create a withdrawal. Returns 201 for new requests and 200 for idempotent replay."
          }
        },
        {
          "name": "Create Deposit",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              },
              {
                "key": "idempotency-key",
                "value": "{{idempotencyKey}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"asset\": \"BTC\",\n  \"amount\": \"0.01\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/wallets/{{walletId}}/deposits",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "wallets",
                "{{walletId}}",
                "deposits"
              ]
            },
            "description": "Create a deposit. Returns 201 for new requests and 200 for idempotent replay."
          }
        }
      ]
    },
    {
      "name": "Mock (Non-Production)",
      "item": [
        {
          "name": "Trigger Failure",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "x-api-key",
                "value": "{{apiKey}}",
                "type": "text"
              },
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"errorType\": \"internal\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/{{apiPrefix}}/mock/failure",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{apiPrefix}}",
                "mock",
                "failure"
              ]
            },
            "description": "Non-production endpoint to intentionally throw failures and increment error metrics. Supported values: invalid_input, entity_not_found, insufficient_balance, asset_mismatch, internal."
          }
        }
      ]
    }
  ]
}
